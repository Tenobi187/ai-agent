# 1. Берем готовый образ с Python (как чистый лист с уже установленной ОС и Python)
FROM python:3.11-slim

# 2. Устанавливаем рабочую директорию внутри контейнера (папка, где будет лежать наш код)
WORKDIR /app

# 3. Копируем файл с зависимостями ВНУТРЬ контейнера
COPY requirements.txt .

# 4. Устанавливаем все библиотеки из requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# 5. Копируем остальной код проекта ВНУТРЬ контейнера (кроме того, что в .dockerignore)
COPY . .

# 6. Указываем порт, который слушает наше приложение (если веб-сервер)
# Это просто метаданные, реально порт открывается при запуске контейнера
EXPOSE 8000

# 7. Команда, которая выполняется при запуске контейнера
# Например, если у вас FastAPI с uvicorn:
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]
# Или если простой скрипт:
# CMD ["python", "main.py"]